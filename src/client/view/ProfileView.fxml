<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="src.client.controller.ProfileController" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-width: 1;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="CẬP NHẬT THÔNG TIN CÁ NHÂN" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #2c3e50;"/>
    
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="90" prefWidth="90" />
            <ColumnConstraints minWidth="220" prefWidth="220" />
        </columnConstraints>
        <children>
            <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtFullName" promptText="Nhập họ tên đầy đủ" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Ngày sinh:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="datePickerDob" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Trường học:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="txtUniversity" promptText="Nhập tên trường học" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="txtEmail" promptText="Nhập địa chỉ Email" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="txtPhone" promptText="Nhập số điện thoại" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        </children>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Lưu thay đổi" onAction="#handleSaveProfile" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="Hủy bỏ" onAction="#handleClose" style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>
</VBox>