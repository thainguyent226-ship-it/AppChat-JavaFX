<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="620.0" prefWidth="880.0"
      style="-fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="src.client.controller.ChatController">
   <children>

      <!-- ================= SIDEBAR: danh sách hội thoại kiểu Messenger ================= -->
      <VBox prefWidth="280.0" minWidth="280.0"
            style="-fx-background-color: #ffffff; -fx-padding: 18 10 15 15; -fx-border-color: transparent #e4e6eb transparent transparent; -fx-border-width: 1;" spacing="14">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10">
               <children>
                  <Label text="Đoạn chat" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                         style="-fx-font-family: 'Segoe UI', Arial; -fx-font-weight: bold; -fx-font-size: 21px; -fx-text-fill: #050505;" />
                  <Button fx:id="btnFriendRequests" text="🔔" onAction="#handleShowFriendRequests" prefWidth="34.0" prefHeight="34.0"
                          style="-fx-background-color: #f0f2f5; -fx-background-radius: 17; -fx-font-size: 15px; -fx-cursor: hand;"/>
               </children>
            </HBox>

            <VBox spacing="6" style="-fx-background-color: #f0f2f5; -fx-padding: 8; -fx-background-radius: 12;">
               <children>
                  <TextField fx:id="txtAddContact" promptText="Nhập username muốn chat..." prefHeight="30.0"
                             style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-font-size: 12px; -fx-border-color: transparent;"/>
                  <Button text="➕ Gửi lời mời kết bạn" onAction="#handleAddContact" maxWidth="Infinity" prefHeight="28.0"
                          style="-fx-background-color: #e7fff0; -fx-text-fill: #16a085; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand; -fx-font-size: 11px;"/>
               </children>
            </VBox>

            <VBox spacing="6" style="-fx-background-color: #f0f2f5; -fx-padding: 8; -fx-background-radius: 12;">
               <children>
                  <TextField fx:id="txtGroupInput" promptText="Nhập tên nhóm..." prefHeight="30.0"
                             style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-font-size: 12px; -fx-border-color: transparent;"/>
                  <HBox spacing="6">
                     <children>
                        <Button text="➕ Tạo nhóm" onAction="#handleCreateGroup" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="28.0"
                                style="-fx-background-color: #e7f3ff; -fx-text-fill: #0084ff; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand; -fx-font-size: 11px;"/>
                        <Button text="🚪 Vào nhóm" onAction="#handleJoinGroup" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="28.0"
                                style="-fx-background-color: #f3e8ff; -fx-text-fill: #9b59b6; -fx-font-weight: bold; -fx-background-radius: 14; -fx-cursor: hand; -fx-font-size: 11px;"/>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <ListView fx:id="listFriends" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-font-family: 'Segoe UI'; -fx-cursor: hand;" />
         </children>
      </VBox>

      <!-- ================= KHUNG CHAT CHÍNH ================= -->
      <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff;">
         <children>

            <!-- Thanh header -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 14 15 14 18; -fx-border-color: transparent transparent #e4e6eb transparent; -fx-border-width: 1;">
               <children>
                  <Label fx:id="lblChattingWith" text="💬 "
                         style="-fx-font-family: 'Segoe UI', Arial; -fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #050505;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />

                  <Button text="❌ Rời nhóm" onAction="#handleLeaveGroup" prefHeight="30.0"
                          style="-fx-background-color: #fff0e6; -fx-background-radius: 15; -fx-text-fill: #e67e22; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>

                  <Button text="👤 Sửa thông tin" onAction="#openProfileWindow" prefHeight="30.0"
                          style="-fx-background-color: #f0f2f5; -fx-background-radius: 15; -fx-text-fill: #050505; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>

                  <Button text="🚪 Đăng xuất" onAction="#handleLogout" prefHeight="30.0"
                          style="-fx-background-color: #fdeaea; -fx-background-radius: 15; -fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>
               </children>
            </HBox>

            <!-- Vùng bong bóng tin nhắn -->
            <ScrollPane fx:id="scrollChat" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #ffffff; -fx-background: #ffffff; -fx-border-color: transparent;">
               <content>
                  <VBox fx:id="vboxMessages" spacing="10" style="-fx-padding: 15 12 15 12; -fx-background-color: #ffffff;" />
               </content>
            </ScrollPane>

            <!-- Thanh nhập tin nhắn -->
            <HBox spacing="10.0" alignment="CENTER" style="-fx-padding: 10 15 16 15;">
               <children>
                  <Button fx:id="btnAttachFile" text="📎" onAction="#handleSendFile" prefWidth="38.0" prefHeight="38.0"
                          style="-fx-background-color: #f0f2f5; -fx-background-radius: 19; -fx-font-size: 15px; -fx-cursor: hand;"/>

                  <Button fx:id="btnSticker" text="😀" onAction="#handleShowStickerPicker" prefWidth="38.0" prefHeight="38.0"
                          style="-fx-background-color: #f0f2f5; -fx-background-radius: 19; -fx-font-size: 15px; -fx-cursor: hand;"/>

                  <TextField fx:id="txtMessage" promptText="Aa" HBox.hgrow="ALWAYS" prefHeight="42.0"
                             style="-fx-background-color: #f0f2f5; -fx-background-radius: 21; -fx-padding: 0 16 0 16; -fx-font-size: 13px; -fx-border-color: transparent;"/>

                  <Button fx:id="btnSend" text="➤" prefWidth="42.0" prefHeight="42.0" onAction="#handleSendMessage"
                          style="-fx-background-color: #0084ff; -fx-background-radius: 21; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand;"/>
               </children>
            </HBox>
         </children>
      </VBox>

   </children>
</HBox>