<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="18.0" prefWidth="380.0" prefHeight="320.0" 
      style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 10);" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="src.client.controller.LoginController">
    
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
    
    <children>
        <Label text="ĐĂNG NHẬP HỆ THỐNG" 
               style="-fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif; -fx-font-weight: 800; -fx-font-size: 20px; -fx-text-fill: #2c3e50; -fx-letter-spacing: 1px;"/>
        
        <TextField fx:id="txtUsername" promptText="Tên đăng nhập / Username" maxWidth="260.0" prefHeight="38.0"
                   style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8; -fx-border-width: 1; -fx-prompt-text-fill: #999999; -fx-font-size: 13px;"/>
        
        <PasswordField fx:id="txtPassword" promptText="Mật khẩu" maxWidth="260.0" prefHeight="38.0"
                       style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-radius: 8; -fx-border-width: 1; -fx-prompt-text-fill: #999999; -fx-font-size: 13px;"/>
        
        <Button text="Đăng Nhập" prefWidth="260.0" prefHeight="40.0" onAction="#handleLogin" 
                style="-fx-background-color: linear-gradient(to right, #3498db, #2980b9); -fx-background-radius: 8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(52,152,219,0.3), 5, 0, 0, 3);"/>
        
        <Button text="Chưa có tài khoản? Đăng ký" onAction="#handleSwitchToRegister" 
                style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold; -fx-underline: false;"/>
    </children>
</VBox>